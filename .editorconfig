# --------------------------------------------------
# Chat Runtime Framework for ChatSpace
# EditorConfig
# --------------------------------------------------

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# --------------------------------------------------
# Markdown
# --------------------------------------------------

[*.md]
trim_trailing_whitespace = false

# --------------------------------------------------
# JSON
# --------------------------------------------------

[*.json]
indent_size = 4

# --------------------------------------------------
# JavaScript
# --------------------------------------------------

[*.{js,mjs,cjs}]
indent_size = 4

# --------------------------------------------------
# CSS
# --------------------------------------------------

[*.css]
indent_size = 4

# --------------------------------------------------
# HTML
# --------------------------------------------------

[*.{html,htm}]
indent_size = 4

# --------------------------------------------------
# PHP
# --------------------------------------------------

[*.php]
indent_size = 4

# --------------------------------------------------
# YAML
# --------------------------------------------------

[*.{yml,yaml}]
indent_size = 2

# --------------------------------------------------
# GitHub Workflows
# --------------------------------------------------

[.github/workflows/*]
indent_size = 2

# --------------------------------------------------
# Batch Files
# --------------------------------------------------

[*.{bat,cmd}]
end_of_line = crlf

# --------------------------------------------------
# PowerShell
# --------------------------------------------------

[*.ps1]
end_of_line = crlf
indent_size = 4